---
// src/pages/cars.astro
import Layout from '../layouts/Layout.astro';
import CustomEl from '../components/CustomEl.astro';
import { withBase } from '../utils/withBase';
---

<Layout title="Cars">
            <h1>Cars Collection 🏎️</h1>
            <h2><a href={withBase('/cars-garage')}>⚙️ Go to Garage Manager ⚙️</a></h2>

            <!-- User's selection to either generate by localStorage or via cloud-->
            <section class="data-controls">
                <button id="load-local" class="data-btn">Load Your Garage</button>
                <button id="load-remote" class="data-btn">Load Kiet's Garage</button>
            </section>

            <section class="projects-grid" id="projects-container">
                <!-- Cards will be generated by JS -->    
            </section>
            
            
            <script is:inline src={withBase('/javascript/project-card.js')}></script>
            <script is:inline src={withBase('/javascript/card-loader.js')}></script>

  <CustomEl />
</Layout>